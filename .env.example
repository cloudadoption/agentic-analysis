# --- Required for codeQuality, contentModel, synthesis ---
BEDROCK_API_KEY=
BEDROCK_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# --- Required for the `cwv` analyzer (vendored cwv-agent) ---
# Same key works for both CrUX + PSI when both APIs are enabled on the project.
GOOGLE_CRUX_API_KEY=
GOOGLE_PAGESPEED_INSIGHTS_API_KEY=

# Gemini API key for cwv-agent's reasoning (https://aistudio.google.com/apikey)
GOOGLE_GEMINI_API_KEY=

# ABSOLUTE path to a service-account JSON with Vertex AI User role.
# Must be absolute — cwv-agent resolves it from its vendor dir, not repo root.
GOOGLE_APPLICATION_CREDENTIALS=
